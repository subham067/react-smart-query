{
  "name": "react-smart-query",
  "version": "1.0.3",
  "description": "Offline-first, normalized, cache-versioned data layer for React Native and Expo. Built on TanStack Query with MMKV (native) and IndexedDB (web).",
  "author": "Subham Ghosh <subham49ghosh@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subham067/react-smart-query.git"
  },
  "homepage": "https://github.com/subham067/react-smart-query#readme",
  "keywords": [
    "react-native",
    "expo",
    "offline-first",
    "cache",
    "tanstack-query",
    "react-query",
    "mmkv",
    "indexeddb",
    "normalized",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    },
    "./debug": {
      "types": "./dist/utils/debug.d.ts",
      "import": "./dist/utils/debug.mjs",
      "require": "./dist/utils/debug.js"
    }
  },
  "files": [
    "dist/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/utils/debug.js",
    "./dist/utils/debug.mjs"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/testing.ts src/utils/debug.ts --format cjs,esm --dts --clean",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "fast-deep-equal": ">=3.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-mmkv": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-mmkv": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.96.2",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "^18.3.28",
    "@types/react-native": "^0.72.8",
    "fast-deep-equal": "^3.1.3",
    "jest": "^29.0.0",
    "jest-expo": "^50.0.0",
    "react": "^19.2.4",
    "react-native": ">=0.72.0",
    "react-native-mmkv": "^4.3.0",
    "babel-jest": "^29.0.0",
    "babel-preset-expo": "~54.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "react-native",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s?(x)"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/react-native/extend-expect"
    ],
    "moduleNameMapper": {
      "^react-native-mmkv$": "<rootDir>/__mocks__/react-native-mmkv.ts"
    }
  },
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/testing.ts",
      "src/utils/debug.ts"
    ],
    "format": [
      "cjs",
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true,
    "treeshake": true,
    "external": [
      "react",
      "react-native",
      "@tanstack/react-query",
      "react-native-mmkv",
      "fast-deep-equal"
    ]
  }
}
